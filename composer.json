{
    "name": "cogepfrance/php-utils",
    "description": "Librairie de composants utilitaires PHP",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Cogep\\PhpUtils\\": "src/"
        }
    },
    "authors": [
        {
            "name": "COGEPFrance"
        }
    ],
    "require": {
        "symfony/string": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/cache-contracts": "^3.6",
        "symfony/dependency-injection": "^8.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/json-streamer": "^8.0",
        "symfony/clock": "^8.0",
        "ext-simplexml": "*",
        "symfony/serializer": "^8.0",
        "php-amqplib/php-amqplib": "^3.7"
    },
    "require-dev": {
        "captainhook/captainhook-phar": "^5.27.4",
        "captainhook/hook-installer": "^1.0.4",
        "mockery/mockery": "^1.6.12",
        "phpstan/phpstan": "^2.1.33",
        "phpstan/phpstan-symfony": "^2.0.9",
        "phpunit/phpunit": "^12.5.5",
        "slevomat/coding-standard": "^8.26",
        "symplify/easy-coding-standard": "^13.0.4",
        "composer/composer": "^2.9"
    },
    "scripts": {
        "post-autoload-dump": "vendor/bin/captainhook install -f -s",
        "check-coverage": "Cogep\\PhpUtils\\Tests\\Dev\\CoverageChecker::run",
        "unit-test": [
            "vendor/bin/phpunit --testsuite Unit",
            "@check-coverage"
        ],
        "phpstan": "vendor/bin/phpstan analyse src/ --level 8 --no-progress",
        "lint": "vendor/bin/ecs check --config=./config/ecs-lint.php --fix",
        "lint-test": "vendor/bin/ecs check --config=./config/ecs-lint.php",
        "complexity": "vendor/bin/ecs check --config=./config/ecs-quality.php --no-progress-bar --ansi"
    },
    "config": {
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "captainhook/captainhook-phar": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
